# Local development environment variables
VAULTKEY_JWT_SECRET=dev-jwt-secret-change-me
VAULTKEY_PRIVATE_KEY_PASSPHRASE=dev-private-passphrase-change-me
VAULTKEY_DATABASE_URI=sqlite:///vaultkey.db
VAULTKEY_CA_CERT_PATH=keys/ca_cert.pem
VAULTKEY_CA_KEY_PATH=keys/ca_key.pem
VAULTKEY_PRIVATE_KEY_STORAGE_PATH=keys/{user_id}_private.pem
VAULTKEY_VAULT_PASSWORD=dev-vault-password-change-in-prod
